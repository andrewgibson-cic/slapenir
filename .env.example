# ============================================================================
# SLAPENIR Environment Configuration - REAL CREDENTIALS (Proxy Only)
# ============================================================================
#
# ⚠️  SECURITY NOTE: This file contains REAL API credentials
# ⚠️  Never commit this file to version control
# ⚠️  The .gitignore file excludes *.env files
#
# ============================================================================
# System Passwords (Optional - defaults provided for development)
# ============================================================================
# For production, set these to strong passwords:
# STEPCA_PASSWORD=your-strong-password-here
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=your-strong-grafana-password

# ============================================================================
# API Credentials
# ============================================================================
# 
# ⚠️  This file is AUTO-GENERATED on agent container startup
# ⚠️  You do NOT need to create this file manually
# ⚠️  NEVER put real credentials here!
#
# This file shows what dummy credentials look like.
# The agent container will automatically generate this file with these values.
#
# How the zero-knowledge architecture works:
#   1. Agent uses: DUMMY_OPENAI
#   2. Proxy intercepts and injects: sk-proj-real-key-123...
#   3. Agent receives sanitized response: [REDACTED]
#
# The agent NEVER sees real credentials!
# ============================================================================

# LLM API Keys (DUMMY - Replaced by Proxy)
OPENAI_API_KEY=DUMMY_OPENAI
ANTHROPIC_API_KEY=DUMMY_ANTHROPIC
GEMINI_API_KEY=DUMMY_GEMINI
MISTRAL_API_KEY=DUMMY_MISTRAL

# Cloud Provider Keys (DUMMY - Replaced by Proxy)
AWS_ACCESS_KEY_ID=DUMMY_AWS_ACCESS
AWS_SECRET_ACCESS_KEY=DUMMY_AWS_SECRET
AWS_REGION=us-east-1
AZURE_API_KEY=DUMMY_AZURE

# Version Control (DUMMY - Replaced by Proxy)
GITHUB_TOKEN=DUMMY_GITHUB
GITLAB_TOKEN=DUMMY_GITLAB

# Communication Services (DUMMY - Replaced by Proxy)
SLACK_BOT_TOKEN=xoxb-DUMMY
SLACK_APP_TOKEN=xapp-DUMMY
SLACK_SIGNING_SECRET=DUMMY_SLACK_SIGNING
DISCORD_BOT_TOKEN=DUMMY_DISCORD
TWILIO_AUTH_TOKEN=DUMMY_TWILIO

# Payment & E-Commerce (DUMMY - Replaced by Proxy)
STRIPE_SECRET_KEY=sk_test_DUMMY
BINANCE_API_KEY=DUMMY_BINANCE
EBAY_OAUTH_TOKEN=v^1.1#DUMMY_EBAY

# Email Services (DUMMY - Replaced by Proxy)
SENDGRID_API_KEY=SG.DUMMY

# IBM Cloud Services (DUMMY - Replaced by Proxy)
IBM_API_KEY=DUMMY_IBM
ICA_API_KEY=DUMMY_ICA
IBM_BASE_URL=https://servicesessentials.ibm.com/apis/v3
IBM_MODEL_ID=global/anthropic.claude-sonnet-4-5-20250929-v1:0

# Research & Academic APIs (DUMMY - Replaced by Proxy)
S2_API_KEY=DUMMY_S2

# ============================================================================
# Proxy Configuration (REQUIRED)
# ============================================================================
# All agent traffic MUST go through the proxy for credential injection
HTTP_PROXY=http://proxy:3000
HTTPS_PROXY=http://proxy:3000
NO_PROXY=localhost,127.0.0.1,proxy

# Python Configuration
PYTHONUNBUFFERED=1

# ============================================================================
# OpenCode Configuration (Zero-Leak Local AI)
# ============================================================================
OPENCODE_DISABLE_CLAUDE_CODE=1
LLAMA_SERVER_HOST=host.docker.internal
LLAMA_SERVER_PORT=8080

# ============================================================================
# NOTE: This file is for reference only
# The actual .env.agent file is auto-generated on container startup
# ============================================================================
# ============================================================================
# Logging Configuration
# ============================================================================
# Control logging behavior for the agent container

# Enable/disable file logging (default: true)
LOG_ENABLED=true

# Log directory path (default: /var/log/slapenir)
LOG_DIR=/var/log/slapenir

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Maximum log file size in bytes before rotation (default: 10485760 = 10MB)
LOG_MAX_BYTES=10485760

# Number of backup log files in keep (default: 5)
LOG_BACKUP_COUNT=5

# Service name for log identification (default: agent-svc)
SERVICE_NAME=agent-svc

# ============================================================================
# Code-Graph-RAG Configuration
# ============================================================================
# Code-Graph-RAG uses local LLM for code analysis
# Set these to point to the Code-Graph-RAG server

# CGR_ORCHESTRATOR_PROVIDER (openai for API compatibility)
CGR_ORCHESTRATOR_PROVIDER=openai

# Model name (ignored by llama-server, uses pre-loaded model)
CGR_ORCHESTRATOR_MODEL=gpt-4o0 # Arbitrary string, llama-server ignores this

# LLM endpoint (Ollama: http://host.docker.internal:11434/v1, llama.cpp: http://host.docker.internal:8080/v1)
CGR_ORCHESTRATOR_ENDPOINT=http://host.docker.internal:11434/v1

# API key (dummy value, llama-server ignores authentication)
CGR_ORCHESTRATOR_API_KEY=sk-local

# Cypher provider (openai for API compatibility)
CGR_CYPHER_PROVIDER=openai

# Model name (ignored by llama-server, uses pre-loaded model)
CGR_CYPHER_MODEL=gpt-4o-mini

# Cypher endpoint (same as orchestrator endpoint)
CGR_CYPHER_ENDPOINT=http://host.docker.internal:11434/v1

# API key (dummy value, llama-server ignores authentication)
CGR_CYPHER_API_KEY=sk-local

# Memgraph connection
CGR_MEMGRAPH_HOST=memgraph
CGR_MEMGRAPH_PORT=7687
CGR_MEMGRAPH_BATCH_SIZE=1000
