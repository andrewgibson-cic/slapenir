# npm proxy configuration for isolated builds
# All traffic routes through SLAPENIR proxy

# Proxy settings
proxy=http://proxy:3000
https-proxy=http://proxy:3000
noproxy=localhost,127.0.0.1,proxy,postgres,host.docker.internal,memgraph

# Strict lock file enforcement
package-lock=true

# Disable SSL verification (proxy handles TLS termination)
strict-ssl=false

# Disable telemetry and analytics
disable=true

# Use registry directly (proxy will handle auth if needed)
registry=https://registry.npmjs.org/

# Cache settings
cache=/home/agent/.npm

# Safety settings
fund=false
audit=true
