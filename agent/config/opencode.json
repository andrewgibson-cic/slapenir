{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-llama/Qwen3.5-Coding-Thinking",
  "share": "disabled",
  "tools": {
    "websearch": false
  },
  "autoupdate": false,
  "experimental": {
    "openTelemetry": false
  },
  "permission": {
    "*": "deny",
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "webfetch": "deny",
    "mcp_*": "deny"
  },
  "provider": {
    "local-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Llama Server",
      "options": {
        "baseURL": "http://host.docker.internal:8080/v1"
      },
      "models": {
        "Qwen3.5-Coding-Thinking": {
          "name": "Qwen 3.5 Coding Thinking (Local)",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "mcpServers": {
    "code-graph-rag": {
      "command": "cgr",
      "args": [
        "mcp-server"
      ],
      "env": {
        "TARGET_REPO_PATH": "/home/agent/workspace",
        "ORCHESTRATOR_PROVIDER": "openai",
        "ORCHESTRATOR_ENDPOINT": "http://host.docker.internal:11434/v1",
        "ORCHESTRATOR_API_KEY": "sk-local",
        "CYPHER_PROVIDER": "openai",
        "CYPHER_ENDPOINT": "http://host.docker.internal:11434/v1",
        "CYPHER_API_KEY": "sk-local",
        "MEMGRAPH_HOST": "memgraph",
        "MEMGRAPH_PORT": "7687"
      }
    }
  }
}
