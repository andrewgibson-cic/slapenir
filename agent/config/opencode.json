{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-llama/qwen3.5-35b-a3b-ud-q4_k_xl",
  "share": "disabled",
  "tools": {
    "websearch": false
  },
  "autoupdate": false,
  "experimental": {
    "openTelemetry": false
  },
  "mcp": {
    "code-graph-rag": {
      "type": "local",
      "command": ["code-graph-rag", "mcp-server"],
      "enabled": true,
      "timeout": 9000000
    },
    "memory": {
      "type": "local",
      "command": ["mcp-server-memory"],
      "enabled": true,
      "timeout": 3600000
    },
    "knowledge": {
      "type": "local",
      "command": ["mcp-local-rag"],
      "enabled": true,
      "timeout": 3600000
    }
  },
