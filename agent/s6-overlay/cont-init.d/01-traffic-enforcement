#!/bin/bash
# SLAPENIR Traffic Enforcement Initialization
# Runs during container initialization to set up iptables rules
# Container runs as root, so this script has root privileges

# Only run if traffic enforcement is enabled
if [ "${TRAFFIC_ENFORCEMENT_ENABLED:-true}" != "true" ]; then
    echo "[traffic-init] Traffic enforcement disabled, skipping"
    exit 0
fi

# Check if ALLOW_BUILD mode is enabled - bypass all restrictions for builds
if [ "${ALLOW_BUILD:-}" = "1" ] || [ "${ALLOW_BUILD:-}" = "true" ]; then
    echo "[traffic-init] ⚠️  ALLOW_BUILD mode enabled - traffic enforcement DISABLED"
    echo "[traffic-init] ⚠️  Agent can connect directly to internet"
    echo "[traffic-init] ⚠️  Use only for builds/tests, disable when done"
    
    # Unset proxy environment variables so tools connect directly
    unset HTTP_PROXY
    unset HTTPS_PROXY
    unset http_proxy
    unset https_proxy
    unset NO_PROXY
    unset no_proxy
    
    # Export to s6 environment for child processes
    s6-env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy -u NO_PROXY -u no_proxy
    
    echo "[traffic-init] ✓ Proxy environment variables removed"
    exit 0
fi

echo "[traffic-init] Setting up traffic enforcement rules..."

# Run the traffic enforcement script (runs as root)
exec /home/agent/scripts/traffic-enforcement.sh
