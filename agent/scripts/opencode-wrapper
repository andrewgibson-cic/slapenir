#!/bin/bash
# Wrapper script for OpenCode CLI with session logging
# Captures all output to /var/log/slapenir while maintaining interactivity

set -e

# Configuration
LOG_DIR="${LOG_DIR:-/var/log/slapenir}"
LOG_ENABLED="${LOG_ENABLED:-true}"
TOOL_NAME="opencode"

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"

# Source detection library if available
if [ -f "$SCRIPT_DIR/lib/detection.sh" ]; then
    source "$SCRIPT_DIR/lib/detection.sh"
fi

# Check if logging is enabled
if [ "$LOG_ENABLED" != "true" ]; then
    # Logging disabled - run opencode directly
    exec /usr/local/bin/opencode "$@"
fi

# Check if we have a TTY (interactive session)
if [ ! -t 0 ]; then
    # Non-interactive mode (piped input) - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Create log directory if needed
if ! mkdir -p "$LOG_DIR" 2>/dev/null; then
    # Cannot create log directory - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Check if log directory is writable
if [ ! -w "$LOG_DIR" ]; then
    # Log directory not writable - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Generate timestamped log file
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
LOG_FILE="${LOG_DIR}/opencode-session-${TIMESTAMP}.log"

# Write session metadata to log file
{
    echo "=== OpenCode Session Started ==="
    echo "Timestamp: $(date -Iseconds)"
    echo "Command: opencode $*"
    echo "User: $(whoami)"
    echo "Working Directory: $(pwd)"
    echo ""
} > "$LOG_FILE"

# Log session start (if detection library is available)
if type log_execution >/dev/null 2>&1; then
    log_execution "$TOOL_NAME" "SESSION_START" "OpenCode session started: $*"
fi

# Create session lock file for build tool detection
LOCK_FILE="/tmp/opencode-session.lock"

cat > "$LOCK_FILE" <<EOF
session_id=${TIMESTAMP}
pid=$$
started=$(date -Iseconds)
command=opencode $*
working_directory=$(pwd)
EOF

# Cleanup function to remove lock file on exit
cleanup_lock() {
    # Log session end (if detection library is available)
    if type log_execution >/dev/null 2>&1; then
        log_execution "$TOOL_NAME" "SESSION_END" "OpenCode session ended"
    fi
    rm -f "$LOCK_FILE" 2>/dev/null || true
}

# Set trap to clean up lock file on exit (normal exit, interrupt, termination, error)
trap cleanup_lock EXIT INT TERM HUP

# Run opencode with tee to capture output
# Use --print-logs flag to get internal OpenCode logs
# Capture both stdout and stderr
# Note: We don't use exec here so the trap remains active
/usr/local/bin/opencode --print-logs "$@" 2>&1 | tee -a "$LOG_FILE"
EXIT_CODE=${PIPESTATUS[0]}

# Exit with the same code as opencode (trap will clean up lock file)
exit $EXIT_CODE
