#!/bin/bash
# Wrapper script for OpenCode CLI with session logging
# Captures all output to /var/log/slapenir while maintaining interactivity

set -e

# Configuration
LOG_DIR="${LOG_DIR:-/var/log/slapenir}"
LOG_ENABLED="${LOG_ENABLED:-true}"

# Check if logging is enabled
if [ "$LOG_ENABLED" != "true" ]; then
    # Logging disabled - run opencode directly
    exec /usr/local/bin/opencode "$@"
fi

# Check if we have a TTY (interactive session)
if [ ! -t 0 ]; then
    # Non-interactive mode (piped input) - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Create log directory if needed
if ! mkdir -p "$LOG_DIR" 2>/dev/null; then
    # Cannot create log directory - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Check if log directory is writable
if [ ! -w "$LOG_DIR" ]; then
    # Log directory not writable - run without logging
    exec /usr/local/bin/opencode "$@"
fi

# Generate timestamped log file
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
LOG_FILE="${LOG_DIR}/opencode-session-${TIMESTAMP}.log"

# Write session metadata to log file
{
    echo "=== OpenCode Session Started ==="
    echo "Timestamp: $(date -Iseconds)"
    echo "Command: opencode $*"
    echo "User: $(whoami)"
    echo "Working Directory: $(pwd)"
    echo ""
} > "$LOG_FILE"

# Run opencode with tee to capture output
# Use --print-logs flag to get internal OpenCode logs
# Capture both stdout and stderr
exec /usr/local/bin/opencode --print-logs "$@" 2>&1 | tee -a "$LOG_FILE"
