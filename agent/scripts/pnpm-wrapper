#!/bin/bash
# pnpm wrapper - Enforces build control for isolated environment
# BLOCKED BY DEFAULT - requires ALLOW_BUILD=1 or PNPM_ALLOW_BUILD=1
#
# Old behavior: Block only during OpenCode sessions
# New behavior: Block always unless explicit override

set -euo pipefail
export TOOL_NAME="pnpm"
source "/home/agent/scripts/lib/build-wrapper.sh"
run_build_wrapper "$@"
